# Copy the backend values into server/.env
PORT=5000
MONGODB_URI=mongodb+srv://<username>:<url_encoded_password>@cluster0.xxxxx.mongodb.net/smart-home-cloud?retryWrites=true&w=majority&appName=Cluster0
CLIENT_URL=http://localhost:5173

# Copy the frontend value into client/.env
VITE_API_BASE_URL=http://localhost:5000/api
